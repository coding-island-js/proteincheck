---
import Layout from '../layouts/Layout.astro';
const API = import.meta.env.PUBLIC_API_URL
  ? `${import.meta.env.PUBLIC_API_URL}/analyze`
  : '/.netlify/functions/analyze';
const SUBSCRIBE = import.meta.env.PUBLIC_API_URL
  ? `${import.meta.env.PUBLIC_API_URL}/subscribe`
  : '';
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Protein Check',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  description:
    'Snap a photo of your meal and get an instant protein estimate, total leucine, and a per-item breakdown.',
  url: 'https://proteincheck.withmagic.ai',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});
---
<Layout
  title="Protein Check — protein & leucine from a meal photo"
  description="Snap a photo of your meal and get an instant protein estimate, total leucine (the muscle-building amino acid), and a per-item breakdown. Free, no signup."
  canonical="/"
  jsonLd={jsonLd}
>
  <main id="main">
    <header class="hero">
      <span class="kicker">Free AI meal analysis</span>
      <h1>How much protein<br /><em>and leucine</em> is on your plate?</h1>
      <p class="sub">Snap your meal. Get the protein, the leucine, and a per-item breakdown in seconds. No signup, no calorie spreadsheet.</p>
    </header>

    <section class="card" aria-label="Protein check tool">
      <!-- STATE 1: intake -->
      <div id="intake" class="intake">
        <label class="drop" id="drop" for="fileInput">
          <span class="drop-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/></svg>
          </span>
          <span class="drop-text">Add a meal photo</span>
          <span class="drop-hint" id="dropHint">Drag &amp; drop, or choose a file</span>
        </label>

        <div class="actions">
          <button id="btnCamera" class="btn primary" type="button" hidden>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/></svg>
            Take photo
          </button>
          <button id="btnUpload" class="btn" type="button">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M12 3v13"/><path d="m7 8 5-5 5 5"/></svg>
            <span id="uploadLabel">Upload photo</span>
          </button>
        </div>

        <input id="camInput" type="file" accept="image/*" capture="environment" hidden />
        <input id="fileInput" type="file" accept="image/*" hidden />
      </div>

      <!-- STATE 2: loading -->
      <div id="loading" class="loading" hidden>
        <div class="thumb-wrap">
          <img id="loadingImg" class="thumb-big" alt="The meal photo you uploaded" />
          <div class="scrim">
            <span class="loader-chip">
              <span class="spinner" aria-hidden="true"></span>
              <span id="loadStep" class="load-step" role="status" aria-live="polite">Looking at your plate…</span>
            </span>
          </div>
        </div>
        <div class="bar" aria-hidden="true"><span class="bar-fill"></span></div>
      </div>

      <!-- STATE 3: result -->
      <div id="result" class="result" hidden aria-live="polite">
        <div class="result-head">
          <img id="resultImg" class="thumb-sm" alt="The meal you analyzed" />
          <p class="verdict" id="verdict"></p>
        </div>

        <div class="stats">
          <div class="stat protein">
            <span class="stat-num"><span id="grams">–</span><span class="stat-unit">g</span></span>
            <span class="stat-label">protein</span>
          </div>
          <div class="stat leucine">
            <span class="stat-num"><span id="leucine">–</span><span class="stat-unit">g</span></span>
            <span class="stat-label">leucine</span>
            <span class="stat-cap">muscle-growth trigger</span>
          </div>
        </div>

        <p id="threshold" class="threshold" hidden></p>

        <ul class="items" id="items"></ul>
        <p class="summary" id="summary"></p>
        <p class="conf" id="conf"></p>

        <button id="again" class="btn primary wide" type="button">Scan another meal</button>

        <form id="subscribe" class="subscribe" hidden>
          <p class="sub-pitch">Coming soon: meal history &amp; PDF export. Want a heads-up?</p>
          <div class="sub-row">
            <input id="subEmail" type="email" inputmode="email" autocomplete="email" placeholder="you@email.com" aria-label="Email for product updates" required />
            <button class="btn primary" type="submit">Notify me</button>
          </div>
          <p id="subMsg" class="sub-msg" role="status" aria-live="polite"></p>
        </form>
      </div>

      <!-- error -->
      <div id="error" class="errorbox" hidden role="alert" aria-live="assertive">
        <p id="errorMsg">Something went wrong reading that photo.</p>
        <button id="retry" class="btn primary" type="button">Try again</button>
      </div>
    </section>

    <section id="how" class="how" aria-label="How it works">
      <h2>How it works</h2>
      <ol class="steps">
        <li><span class="step-n">1</span><strong>Snap your plate</strong><p>Any meal, any angle.</p></li>
        <li><span class="step-n">2</span><strong>AI reads it</strong><p>Protein &amp; leucine, per item.</p></li>
        <li><span class="step-n">3</span><strong>See the breakdown</strong><p>Totals, then details. Nothing stored.</p></li>
      </ol>
      <p class="why"><strong>Why leucine?</strong> It's the trigger for muscle growth — it flips on the mTOR pathway, and most trackers bury it. Aim for <strong>~2.5–3g a meal</strong> (about 20–30g of quality protein). Leucine pulls the trigger; the other essential amino acids do the building.</p>
      <p class="learn-link"><a href="/learn">Read the protein &amp; leucine guides →</a></p>
    </section>
  </main>

  <script define:vars={{ API, SUBSCRIBE }}>
    const $ = (id) => document.getElementById(id);
    const intake = $('intake'), loading = $('loading'), result = $('result'), errorBox = $('error');
    const camInput = $('camInput'), fileInput = $('fileInput');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const isMobile =
      window.matchMedia('(hover: none) and (pointer: coarse)').matches ||
      /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

    if (isMobile) {
      $('btnCamera').hidden = false;
      $('uploadLabel').textContent = 'Upload photo';
      $('dropHint').textContent = 'Take a new photo or pick one from your library';
    } else {
      $('uploadLabel').textContent = 'Upload a photo';
      $('dropHint').textContent = 'Drag & drop, or upload a photo';
    }

    // Email capture only works against the real API (not the function-only fallback).
    if (SUBSCRIBE) $('subscribe').hidden = false;

    function show(state) {
      for (const el of [intake, loading, result, errorBox]) el.hidden = el !== state;
    }

    async function downscale(fileObj, max = 1024) {
      const url = URL.createObjectURL(fileObj);
      const img = await new Promise((res, rej) => {
        const i = new Image();
        i.onload = () => res(i); i.onerror = rej; i.src = url;
      });
      const scale = Math.min(1, max / Math.max(img.width, img.height));
      const c = document.createElement('canvas');
      c.width = Math.round(img.width * scale);
      c.height = Math.round(img.height * scale);
      c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
      URL.revokeObjectURL(url);
      return c.toDataURL('image/jpeg', 0.85);
    }

    function round1(n) { return (Math.round((n ?? 0) * 10) / 10).toFixed(1); }

    function renderResult(d) {
      const items = d.items || [];
      const protein = Number(d.totalProtein ?? 0);
      // No food found / unreadable photo: show a friendly retry, not a fake 0g card.
      if (protein <= 0 && items.length === 0) {
        $('errorMsg').textContent =
          (d.summary && d.verdict !== 'Could not read that photo')
            ? d.summary
            : "Couldn't read that one. Try a clearer, well-lit photo of just the food.";
        show(errorBox);
        return;
      }
      const leu = Number(d.totalLeucine ?? 0);
      $('grams').textContent = Math.round(d.totalProtein ?? 0);
      $('leucine').textContent = round1(leu);
      $('verdict').textContent = d.verdict || '';
      $('items').innerHTML = (d.items || [])
        .map((it) => {
          const l = it.leucine != null ? `<span class="il">${round1(it.leucine)}g leucine</span>` : '';
          return `<li><span class="in">${it.name}</span><span class="iv"><span class="ip">${Math.round(it.protein)}g</span>${l}</span></li>`;
        })
        .join('');
      $('summary').textContent = d.summary || '';
      $('conf').textContent = d.confidence ? `Confidence: ${d.confidence}` : '';

      const th = $('threshold');
      if ((d.totalProtein ?? 0) > 0) {
        const hit = leu >= 2.5;
        th.textContent = hit
          ? `Hits the ~2.5g leucine threshold for muscle growth`
          : `Below the ~2.5g leucine threshold — add a complete protein`;
        th.className = 'threshold ' + (hit ? 'hit' : 'miss');
        th.hidden = false;
      } else {
        th.hidden = true;
      }

      show(result);
      result.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
    }

    // Cycle through real pipeline steps, then keep rotating reassurance lines so
    // the user always sees the text change — clear signal it hasn't hung.
    // Honest captions: the analysis is a single AI call, so we state what's truly
    // happening ("Analyzing…") and rotate honest "still working" lines for longer
    // waits — no fake per-step progress. The moving bar shows it isn't hung.
    const STEPS = ['Analyzing your meal…'];
    const SLOW = [
      'Still analyzing…',
      'Reading the photo carefully…',
      'Working on the estimate…',
      'Taking a closer look…',
      'Crunching the numbers…',
      'Sizing up the portions…',
      'Putting it all together…',
      'Just a few more seconds…',
      'Almost there…',
      'Hang tight, still working…',
      'Wrapping up the numbers…',
      'Nearly done…',
    ];
    function startSteps() {
      const el = $('loadStep');
      let i = 0;
      el.textContent = STEPS[0];
      const t = setInterval(() => {
        i++;
        el.textContent = i < STEPS.length ? STEPS[i] : SLOW[(i - STEPS.length) % SLOW.length];
      }, 1200);
      return () => clearInterval(t);
    }

    async function handleFile(f) {
      if (!f) return;
      let dataUrl;
      try {
        dataUrl = await downscale(f);
      } catch {
        $('errorMsg').textContent = "That file doesn't look like a photo. Pick an image and try again.";
        show(errorBox);
        return;
      }
      $('loadingImg').src = dataUrl;
      $('resultImg').src = dataUrl;
      show(loading);
      const stopSteps = startSteps();
      const ctrl = new AbortController();
      const timeout = setTimeout(() => ctrl.abort(), 30000);
      try {
        const r = await fetch(API, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ image: dataUrl }),
          signal: ctrl.signal,
        });
        if (!r.ok) throw new Error('Server ' + r.status);
        renderResult(await r.json());
      } catch (e) {
        $('errorMsg').textContent = e && e.name === 'AbortError'
          ? 'That took longer than expected. Please try again.'
          : 'Something went wrong reading that photo. Please try again.';
        show(errorBox);
      } finally {
        clearTimeout(timeout);
        stopSteps();
      }
    }

    function reset() {
      camInput.value = '';
      fileInput.value = '';
      $('subEmail').disabled = false;
      $('subEmail').value = '';
      $('subMsg').textContent = '';
      document.querySelector('.sub-pitch').hidden = false;
      document.querySelector('.sub-row').hidden = false;
      show(intake);
    }

    // Passive email capture (optional, appears after a result).
    $('subscribe').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = $('subEmail').value.trim();
      if (!email || !SUBSCRIBE) return;
      $('subMsg').textContent = 'Saving…';
      try {
        await fetch(SUBSCRIBE, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ email, source: 'result' }),
        });
        // Collapse the form to a clean confirmation (best practice).
        document.querySelector('.sub-pitch').hidden = true;
        document.querySelector('.sub-row').hidden = true;
        $('subMsg').textContent = "You're on the list. Thanks!";
      } catch {
        $('subMsg').textContent = 'Could not save that just now — try again later.';
      }
    });

    camInput.addEventListener('change', () => handleFile(camInput.files?.[0]));
    fileInput.addEventListener('change', () => handleFile(fileInput.files?.[0]));
    $('btnCamera').addEventListener('click', () => camInput.click());
    $('btnUpload').addEventListener('click', () => fileInput.click());
    $('again').addEventListener('click', reset);
    $('retry').addEventListener('click', reset);

    // Desktop drag & drop.
    const drop = $('drop');
    ['dragenter', 'dragover'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); }));
    ['dragleave', 'drop'].forEach((ev) =>
      drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); }));
    drop.addEventListener('drop', (e) => {
      const f = e.dataTransfer?.files?.[0];
      if (f) handleFile(f);
    });
  </script>

  <style>
    main { max-width:var(--maxw); margin:0 auto; padding:40px 20px 8px; }

    .hero { text-align:center; margin-bottom:24px; }
    .kicker { display:inline-block; font-size:12px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--accent); background:var(--accent-soft); padding:5px 12px; border-radius:999px; margin-bottom:16px; }
    h1 { font-size:clamp(32px,7vw,44px); margin:0 0 12px; }
    h1 em { font-style:normal; color:var(--accent); }
    .sub { color:var(--ink-soft); font-size:16.5px; margin:0 auto; max-width:32em; }

    .card { background:var(--bg-card); border:1px solid var(--line); border-radius:var(--radius-lg); padding:18px; box-shadow:var(--shadow); }

    /* intake */
    .drop { display:flex; flex-direction:column; align-items:center; gap:7px; border:2px dashed #cdd5cc; border-radius:var(--radius); padding:30px 16px; text-align:center; cursor:pointer; transition:border-color .15s, background .15s; }
    .drop:hover, .drop.over { border-color:var(--accent); background:var(--accent-soft); }
    .drop-icon { color:var(--accent); display:flex; }
    .drop-text { font-weight:700; font-size:18px; }
    .drop-hint { color:var(--ink-muted); font-size:13.5px; }
    .actions { display:flex; gap:10px; margin-top:14px; }
    .actions .btn { flex:1; }

    .btn { display:inline-flex; align-items:center; justify-content:center; gap:8px; border:1px solid var(--line); background:var(--bg-card); color:var(--ink); border-radius:12px; padding:13px 18px; font:inherit; font-weight:700; font-size:16px; cursor:pointer; transition:border-color .15s, background .15s, color .15s; min-height:48px; }
    .btn:hover { border-color:var(--accent); color:var(--accent); }
    .btn.primary { background:var(--accent); border-color:var(--accent); color:#fff; }
    .btn.primary:hover { background:var(--accent-ink); border-color:var(--accent-ink); color:#fff; }
    .btn.wide { width:100%; margin-top:4px; }
    .btn svg { flex:none; }

    /* loading */
    .loading { text-align:center; }
    .thumb-wrap { position:relative; display:inline-block; border-radius:var(--radius); overflow:hidden; max-width:100%; }
    .thumb-big { display:block; max-height:300px; max-width:100%; }
    .scrim { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(22,32,27,.28); backdrop-filter:blur(3px); -webkit-backdrop-filter:blur(3px); }
    .loader-chip { display:inline-flex; align-items:center; gap:10px; background:rgba(255,255,255,.94); border-radius:999px; padding:9px 16px 9px 11px; box-shadow:0 6px 20px rgba(16,40,28,.18); max-width:90%; }
    .load-step { font-size:14px; font-weight:700; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .spinner { width:20px; height:20px; flex:none; border:3px solid color-mix(in srgb, var(--accent) 22%, transparent); border-top-color:var(--accent); border-radius:50%; animation:spin .8s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .bar { height:5px; background:var(--line-soft); border-radius:999px; margin:16px auto 0; max-width:240px; overflow:hidden; position:relative; }
    .bar-fill { position:absolute; top:0; left:-45%; height:100%; width:40%; background:var(--accent); border-radius:999px; animation:slide 1.15s ease-in-out infinite; }
    @keyframes slide { to { left:105%; } }

    /* result */
    .result-head { display:flex; align-items:center; gap:14px; margin-bottom:16px; }
    .thumb-sm { width:60px; height:60px; object-fit:cover; border-radius:12px; flex:none; }
    .verdict { font-weight:800; font-size:20px; letter-spacing:-.01em; line-height:1.25; margin:0; }

    .stats { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .stat { border-radius:var(--radius); padding:16px 12px 14px; text-align:center; }
    .stat.protein { background:var(--accent-soft); }
    .stat.leucine { background:var(--leu-soft); }
    .stat-num { font-weight:800; font-size:44px; letter-spacing:-.03em; line-height:1; display:inline-flex; align-items:baseline; }
    .stat.protein .stat-num { color:var(--accent-ink); }
    .stat.leucine .stat-num { color:var(--leu-ink); }
    .stat-unit { font-size:18px; margin-left:2px; }
    .stat-label { display:block; margin-top:6px; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; }
    .stat.protein .stat-label { color:var(--accent-ink); }
    .stat.leucine .stat-label { color:var(--leu-ink); }
    .stat-cap { display:block; font-size:11px; color:var(--leu); font-weight:600; margin-top:2px; }

    .threshold { margin:14px 0 0; padding:10px 14px; border-radius:10px; font-size:13.5px; font-weight:600; text-align:center; }
    .threshold.hit { background:var(--accent-soft); color:var(--accent-ink); }
    .threshold.miss { background:var(--leu-soft); color:var(--leu-ink); }

    /* Item rows are injected via innerHTML, so they don't get Astro's scope
       attribute — these must be :global to apply to dynamically-created nodes. */
    :global(.items) { list-style:none; margin:18px 0 0; padding:0; }
    :global(.items li) { display:flex; justify-content:space-between; align-items:center; gap:12px; padding:11px 2px; border-bottom:1px solid var(--line-soft); }
    :global(.items li:last-child) { border-bottom:none; }
    :global(.in) { font-weight:600; }
    :global(.iv) { text-align:right; white-space:nowrap; }
    :global(.ip) { font-weight:800; color:var(--accent-ink); }
    :global(.il) { display:block; font-size:12px; color:var(--leu); font-weight:600; }

    .summary { color:var(--ink-soft); font-size:15px; margin:16px 0 4px; }
    .conf { color:var(--ink-muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; margin:0 0 16px; }

    .subscribe { margin-top:14px; padding-top:14px; border-top:1px solid var(--line-soft); }
    .sub-pitch { font-size:12.5px; color:var(--ink-muted); text-align:center; margin:0 0 8px; }
    .sub-row { display:flex; gap:6px; }
    .sub-row input { flex:1; min-width:0; border:1px solid var(--line); border-radius:10px; padding:9px 12px; font:inherit; font-size:14px; min-height:40px; color:var(--ink); background:var(--bg); }
    .sub-row input::placeholder { color:var(--ink-muted); }
    .sub-row input:hover { border-color:#cdd5cc; }
    .sub-row .btn { flex:none; min-height:40px; padding:9px 16px; font-size:14px; border-radius:10px; }
    .sub-msg { font-size:12.5px; font-weight:600; color:var(--accent-ink); text-align:center; margin:8px 0 0; min-height:0; }
    .sub-msg:empty { display:none; }

    .errorbox { text-align:center; padding:10px 4px; }
    .errorbox p { font-weight:600; margin:0 0 14px; }

    /* how it works */
    .how { margin:48px auto 8px; }
    .how h2 { font-size:24px; text-align:center; margin:0 0 24px; }
    .steps { list-style:none; margin:0; padding:0; display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
    .steps li { text-align:center; display:flex; flex-direction:column; align-items:center; gap:4px; }
    .step-n { width:34px; height:34px; border-radius:50%; background:var(--accent-soft); color:var(--accent-ink); font-weight:800; font-size:15px; display:flex; align-items:center; justify-content:center; margin-bottom:6px; }
    .steps strong { font-size:15px; }
    .steps p { margin:0; color:var(--ink-soft); font-size:13.5px; line-height:1.45; }
    .why { margin:30px auto 0; padding:16px 18px; background:var(--bg-card); border:1px solid var(--line); border-radius:var(--radius); color:var(--ink-soft); font-size:14.5px; line-height:1.6; text-align:center; max-width:34em; }
    .why strong { color:var(--ink); }
    .learn-link { text-align:center; margin:16px 0 0; }
    .learn-link a { font-weight:700; font-size:15px; text-decoration:none; }

    @media (max-width:380px) {
      .stat-num { font-size:40px; }
      .actions { flex-direction:column; }
    }
  </style>
</Layout>
