generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One protein scan. We store the derived estimate, never the raw photo.
model Scan {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  totalProtein Int      @default(0)
  totalLeucine Float    @default(0)
  items        Json
  verdict      String
  summary      String
  confidence   String   @default("low")
  email        String?
  sessionId    String?

  @@index([createdAt])
}

/// Email signups for product updates (history, PDF export). No raw photos here.
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  source    String?

  @@index([createdAt])
}
