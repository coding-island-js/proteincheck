---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { SITE, SITE_NAME, AUTHOR, fmtDate, SOURCES } from '../lib/blog.mjs';
import { getStats, MIN_PUBLISH } from '../lib/stats.mjs';

const stats = await getStats();
const live = stats.count >= MIN_PUBLISH;
const refs = [SOURCES.issn, SOURCES.usda, SOURCES.medline];

// Dataset schema only once the numbers are real and indexable.
const jsonLd = live
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Dataset',
      name: 'Protein Check — protein in real meals',
      description: `Aggregate protein and leucine estimates from ${stats.count} meals checked with Protein Check.`,
      url: `${SITE}/data`,
      creator: { '@type': 'Organization', name: SITE_NAME, url: `${SITE}/` },
      dateModified: stats.lastDay,
      license: 'https://creativecommons.org/licenses/by/4.0/',
      variableMeasured: ['protein (g) per meal', 'leucine (g) per meal'],
    })
  : undefined;

Astro.response.headers.set(
  'Netlify-CDN-Cache-Control',
  'public, s-maxage=600, stale-while-revalidate=86400'
);
---
<Layout
  title={live ? `What ${stats.count.toLocaleString()} real meals reveal about protein — ${SITE_NAME}` : `Protein data — ${SITE_NAME}`}
  description={live
    ? `Across ${stats.count.toLocaleString()} meals checked with Protein Check, the average had ${stats.meanP} g of protein and ${stats.pctLeu}% hit the leucine threshold for muscle growth.`
    : 'Anonymous, aggregate protein data from real meals checked with Protein Check — the live numbers appear here as people use the tool.'}
  canonical="/data"
  noindex={!live}
  jsonLd={jsonLd}
>
  <main id="main" class="prose">
    <p class="crumb"><a href="/">Protein Check</a><span class="sep">/</span>data</p>
    <h1>How much protein is really on people's plates?</h1>

    {live ? (
      <>
        <p class="updated">By <a href="/about">{AUTHOR.name}</a> · {stats.count.toLocaleString()} meals · Updated {fmtDate(stats.lastDay)}</p>

        <div class="answer">
          <p>Across <strong>{stats.count.toLocaleString()} meals</strong> checked with Protein Check, the average meal had about <strong>{stats.meanP} g of protein</strong> and <strong>{stats.meanL} g of leucine</strong>. Only <strong>{stats.pctLeu}%</strong> reached the ~2.5 g leucine threshold tied to muscle protein synthesis, and <strong>{stats.pct20}%</strong> hit at least 20 g of protein. Most meals fall in the <strong>{stats.medianRange}</strong> range — short of a single muscle-building dose for most adults.</p>
        </div>

        <ul class="quick">
          <li><span class="qv">{stats.meanP} g</span><span class="ql">avg protein / meal</span></li>
          <li><span class="qv">{stats.meanL} g</span><span class="ql">avg leucine / meal</span></li>
          <li><span class="qv">{stats.pctLeu}%</span><span class="ql">hit the leucine threshold</span></li>
          <li><span class="qv">{stats.pct20}%</span><span class="ql">reached 20 g protein</span></li>
        </ul>

        <h2>How protein per meal is distributed</h2>
        <ul class="dist">
          {stats.dist.map((d) => (
            <li>
              <span class="d-label">{d.label}</span>
              <span class="d-bar"><span class="d-fill" style={`width:${d.barPct}%`}></span></span>
              <span class="d-pct">{d.pct}%</span>
            </li>
          ))}
        </ul>

        <h2>What this means</h2>
        <p>A single meal needs roughly 20–40 g of quality protein (about 2.5–3 g of leucine) to maximally trigger muscle protein synthesis. With most checked meals landing in the {stats.medianRange} range, the practical takeaway is simple: most people aren't short on food, they're short on <em>protein per meal</em> — front-loading breakfast and adding a complete-protein source is the easiest fix.</p>

        <div class="cta-box">
          <p>Curious how your own meal stacks up against these numbers? Snap a photo and the free <strong>Protein Check</strong> estimates its protein and leucine in seconds.</p>
          <p><a class="cta-tool" href="/">Check my meal →</a></p>
        </div>

        <h2>Methodology</h2>
        <p>These figures come from anonymous, aggregate estimates produced when people check a meal photo with Protein Check. Each estimate is generated by a vision model and is approximate. We store only the aggregate numbers — never the photo, and nothing tied to a person. The sample grows over time; this page updates automatically. Estimates are general information, not medical advice.</p>
      </>
    ) : (
      <>
        <p class="updated">By <a href="/about">{AUTHOR.name}</a></p>
        <div class="answer">
          <p>We're gathering anonymous, aggregate data from real meal checks — average protein per meal, how often meals hit the leucine threshold for muscle growth, and how protein is distributed across everyday plates. The live numbers will appear here as people use the tool.</p>
        </div>
        <p>Want to add a data point? <a href="/">Check a meal</a> — only the anonymous estimate is counted, never your photo. Or <a href="/learn">read the protein guides</a> in the meantime.</p>
      </>
    )}

    <h2 class="src-h">Sources</h2>
    <ul class="sources">
      {refs.map((s) => (
        <li><a href={s.url} target="_blank" rel="noopener nofollow">{s.label}</a></li>
      ))}
    </ul>

    <hr />
    <p class="soon"><a href="/learn">← all guides</a></p>
  </main>

  <style>
    .dist { list-style:none; padding:0; margin:14px 0 4px; }
    .dist li { display:grid; grid-template-columns:64px 1fr 40px; align-items:center; gap:10px; padding:5px 0; margin:0; border:none; }
    .d-label { font-size:13px; color:var(--ink-muted); font-weight:600; white-space:nowrap; }
    .d-bar { background:var(--line-soft); border-radius:999px; height:14px; overflow:hidden; }
    .d-fill { display:block; height:100%; background:var(--accent); border-radius:999px; }
    .d-pct { font-size:13px; color:var(--ink-soft); font-weight:700; text-align:right; }
  </style>
</Layout>
