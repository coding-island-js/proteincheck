---
const API = import.meta.env.PUBLIC_API_URL
  ? `${import.meta.env.PUBLIC_API_URL}/analyze`
  : '/.netlify/functions/analyze';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Protein Check — how much protein is in your meal?</title>
    <meta name="description" content="Snap a photo of your meal and get an instant protein estimate with a per-item breakdown." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <header class="hero">
        <h1>Protein Check</h1>
        <p class="sub">Snap a photo of your meal. Get an instant protein estimate with a per-item breakdown.</p>
      </header>

      <section class="card" aria-label="Protein check">
        <label class="drop" id="drop">
          <input id="file" type="file" accept="image/*" capture="environment" hidden />
          <span class="drop-inner">
            <span class="cam" aria-hidden="true">🍽️</span>
            <span class="drop-text">Take or upload a meal photo</span>
            <span class="drop-hint">Plate, bowl, snack — anything</span>
          </span>
        </label>

        <div id="preview-wrap" hidden>
          <img id="preview" alt="Your meal photo" />
          <button id="again" class="ghost" type="button">Use a different photo</button>
        </div>

        <div id="status" class="status" role="status" aria-live="polite"></div>

        <div id="result" class="result" hidden aria-live="polite">
          <div class="total">
            <span class="grams" id="grams">–</span>
            <span class="unit">g protein</span>
          </div>
          <p class="verdict" id="verdict"></p>
          <ul class="items" id="items"></ul>
          <p class="summary" id="summary"></p>
          <p class="conf" id="conf"></p>
        </div>
      </section>

      <footer class="foot">
        <p>Estimates only — your photo is analyzed and discarded, never stored. Built with Astro + a typed NestJS API + Gemini vision.</p>
      </footer>
    </main>

    <script define:vars={{ API }}>
      const $ = (id) => document.getElementById(id);
      const file = $('file'), drop = $('drop'), status = $('status'), result = $('result');

      async function downscale(fileObj, max = 1024) {
        const url = URL.createObjectURL(fileObj);
        const img = await new Promise((res, rej) => {
          const i = new Image();
          i.onload = () => res(i); i.onerror = rej; i.src = url;
        });
        const scale = Math.min(1, max / Math.max(img.width, img.height));
        const c = document.createElement('canvas');
        c.width = Math.round(img.width * scale);
        c.height = Math.round(img.height * scale);
        c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
        URL.revokeObjectURL(url);
        return c.toDataURL('image/jpeg', 0.85);
      }

      function showResult(d) {
        $('grams').textContent = Math.round(d.totalProtein ?? 0);
        $('verdict').textContent = d.verdict || '';
        $('items').innerHTML = (d.items || [])
          .map((it) => `<li><span>${it.name}</span><span class="ig">${Math.round(it.protein)}g</span></li>`)
          .join('');
        $('summary').textContent = d.summary || '';
        $('conf').textContent = d.confidence ? `Confidence: ${d.confidence}` : '';
        result.hidden = false;
      }

      file.addEventListener('change', async () => {
        const f = file.files?.[0];
        if (!f) return;
        result.hidden = true;
        const dataUrl = await downscale(f);
        $('preview').src = dataUrl;
        $('preview-wrap').hidden = false;
        drop.hidden = true;
        status.textContent = 'Counting your protein…';
        try {
          const r = await fetch(API, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ image: dataUrl }),
          });
          if (!r.ok) throw new Error('Server ' + r.status);
          showResult(await r.json());
          status.textContent = '';
        } catch (e) {
          status.textContent = 'Something went wrong reading that photo. Please try again.';
        }
      });

      $('again').addEventListener('click', () => {
        file.value = '';
        $('preview-wrap').hidden = true;
        drop.hidden = false;
        result.hidden = true;
        status.textContent = '';
      });
    </script>

    <style>
      :root { --ink:#171717; --muted:#6b6b6b; --line:#e7e4dd; --accent:#0b8e96; --bg:#faf8f3; }
      * { box-sizing: border-box; }
      body { margin:0; background:var(--bg); color:var(--ink); font-family:Inter,system-ui,sans-serif; line-height:1.5; }
      main { max-width:560px; margin:0 auto; padding:48px 20px 64px; }
      .hero { text-align:center; margin-bottom:28px; }
      h1 { font-family:'DM Serif Display',serif; font-size:clamp(40px,9vw,60px); margin:0 0 10px; letter-spacing:-.5px; }
      .sub { color:var(--muted); font-size:17px; margin:0 auto; max-width:30em; }
      .card { background:#fff; border:1px solid var(--line); border-radius:16px; padding:20px; box-shadow:0 6px 30px rgba(0,0,0,.05); }
      .drop { display:block; border:2px dashed #d8d2c6; border-radius:14px; padding:38px 16px; text-align:center; cursor:pointer; transition:.15s; }
      .drop:hover, .drop:focus-within { border-color:var(--accent); background:#f4fbfb; }
      .drop-inner { display:flex; flex-direction:column; gap:6px; align-items:center; }
      .cam { font-size:34px; }
      .drop-text { font-weight:700; font-size:18px; }
      .drop-hint { color:var(--muted); font-size:14px; }
      #preview-wrap { display:flex; flex-direction:column; align-items:center; gap:12px; }
      #preview { max-height:320px; max-width:100%; border-radius:12px; }
      .ghost { background:none; border:1px solid var(--line); border-radius:999px; padding:8px 16px; font:inherit; font-weight:600; cursor:pointer; color:var(--ink); }
      .ghost:hover { border-color:var(--accent); color:var(--accent); }
      .status { text-align:center; color:var(--muted); margin-top:14px; min-height:22px; font-weight:500; }
      .result { margin-top:20px; padding-top:20px; border-top:1px solid var(--line); }
      .total { display:flex; align-items:baseline; gap:8px; justify-content:center; margin-bottom:6px; }
      .grams { font-family:'DM Serif Display',serif; font-size:64px; color:var(--accent); line-height:1; }
      .unit { color:var(--muted); font-weight:700; font-size:20px; }
      .verdict { text-align:center; font-weight:800; font-size:21px; margin:6px 0 16px; }
      .items { list-style:none; margin:0 0 16px; padding:0; }
      .items li { display:flex; justify-content:space-between; padding:9px 4px; border-bottom:1px solid var(--line); }
      .items li .ig { font-weight:700; color:var(--accent); }
      .summary { color:var(--muted); text-align:center; font-size:15px; margin:0 0 6px; }
      .conf { text-align:center; color:#9a9a9a; font-size:12px; text-transform:uppercase; letter-spacing:.04em; margin:0; }
      .foot { text-align:center; color:var(--muted); font-size:13px; margin-top:24px; }
    </style>
  </body>
</html>
