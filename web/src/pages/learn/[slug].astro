---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import {
  SITE,
  store,
  getQueue,
  getBody,
  published,
  siblingsFor,
  monthYear,
  AUTHOR,
  breadcrumbLd,
  articleLd,
  howToLd,
  faqLd,
} from '../../lib/blog.mjs';

const { slug } = Astro.params;
const s = await store();
const q = await getQueue(s);
const topic = published(q).find((t) => t.slug === slug);
const body = topic ? await getBody(s, slug) : null;

if (!topic || !body) Astro.response.status = 404;

const url = `${SITE}/learn/${slug}`;
const IMG_V = 3; // bump to bust the OG-image CDN cache after a re-image pass
const ogPath = `/learn/og/${slug}.png?v=${IMG_V}`;
const siblings = topic ? siblingsFor(topic, q) : [];
const paras = (t) => String(t || '').split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);

let jsonLd;
if (topic && body) {
  const blocks = [breadcrumbLd(body.crumbTail, url), articleLd(topic, body, url)];
  if (Array.isArray(body.steps) && body.steps.length) blocks.push(howToLd(topic, body));
  if (Array.isArray(body.faqs) && body.faqs.length) blocks.push(faqLd(body));
  jsonLd = blocks.map((o) => JSON.stringify(o)).join('</script>\n<script type="application/ld+json">');
}

Astro.response.headers.set(
  'Netlify-CDN-Cache-Control',
  'public, s-maxage=300, stale-while-revalidate=86400'
);
---
{topic && body ? (
  <Layout
    title={topic.title}
    description={body.metaDescription}
    canonical={`/learn/${slug}`}
    ogType="article"
    ogImage={ogPath}
    jsonLd={jsonLd}
  >
    <main id="main" class="prose">
      <p class="crumb"><a href="/">Protein Check</a><span class="sep">/</span><a href="/learn">learn</a><span class="sep">/</span>{body.crumbTail}</p>
      <h1>{topic.title}</h1>
      <p class="updated">Updated <b>{monthYear()}</b> · ~2-minute read · by {AUTHOR.name}</p>

      <img class="hero" src={ogPath} width="1200" height="630" loading="eager" alt={`Illustration for ${topic.title}`} />

      <div class="answer">
        {paras(body.answer).map((p) => <p>{p}</p>)}
      </div>

      {Array.isArray(body.quickNumbers) && body.quickNumbers.length > 0 && (
        <ul class="quick">
          {body.quickNumbers.map((n) => (
            <li><span class="qv">{n.value}</span><span class="ql">{n.label}</span></li>
          ))}
        </ul>
      )}

      {Array.isArray(body.foods) && body.foods.length > 0 && (
        <ul class="foods">
          {body.foods.map((f) => (
            <li>
              <span class="f-main">
                <span class="f-name">{f.name}</span>
                {f.serving && <span class="f-serving">{f.serving}</span>}
              </span>
              <span class="f-protein">{f.protein}</span>
            </li>
          ))}
        </ul>
      )}

      {Array.isArray(body.sections) && body.sections.map((sec) => (
        <>
          <h2>{sec.h2}</h2>
          {paras(sec.body).map((p) => <p>{p}</p>)}
        </>
      ))}

      {Array.isArray(body.steps) && body.steps.length > 0 && (
        <ol>
          {body.steps.map((m) => (
            <li><strong>{m.lead}.</strong> {m.text}</li>
          ))}
        </ol>
      )}

      {body.cue && <p class="cue-line">Remember: <em>{body.cue}</em></p>}

      {siblings.length > 0 && (
        <>
          <h2>Related guides</h2>
          <ul class="related">
            {siblings.map((sib) => (
              <li><a href={`/learn/${sib.slug}`}>{sib.title}</a></li>
            ))}
          </ul>
        </>
      )}

      <div class="cta-box">
        <p>Want to know how much protein is actually on <em>your</em> plate? Snap a photo and the free <strong>Protein Check</strong> estimates the protein and leucine in seconds — no signup.</p>
        <p><a class="cta-tool" href="/">Check my meal →</a></p>
      </div>

      {Array.isArray(body.faqs) && body.faqs.length > 0 && (
        <>
          {body.faqs.map((f) => (
            <>
              <h2>{f.q}</h2>
              {paras(f.a).map((p) => <p>{p}</p>)}
            </>
          ))}
        </>
      )}

      <hr />
      <p class="soon"><a href="/learn">← all guides</a></p>
      <p class="disclaimer">General information from a real person who builds nutrition tools — not medical or dietary advice. Numbers are estimates; talk to a professional for advice specific to you.</p>
    </main>
  </Layout>
) : (
  <Layout title="Guide not found — Protein Check" description="That guide doesn't exist yet." noindex={true}>
    <main id="main" class="prose">
      <p class="crumb"><a href="/">Protein Check</a><span class="sep">/</span>learn</p>
      <h1>Guide not found</h1>
      <p>That guide doesn't exist (yet). Browse the <a href="/learn">learn hub</a> or <a href="/">check your meal</a>.</p>
    </main>
  </Layout>
)}
